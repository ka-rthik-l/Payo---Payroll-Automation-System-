DATABASE_URL="mysql://root:password@localhost:3306/payo"
PORT=3000
NODE_ENV=development

FRONTEND_URL=http://localhost:5173

# SMTP credentials — ENV ONLY (never stored in database)
SMTP_HOST=smtp.payo.co
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads

# Demo parity: EMP004 fails on first email attempt
SIMULATE_EMAIL_FAILURE=true
